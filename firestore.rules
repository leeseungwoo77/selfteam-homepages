rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isLeader() { return isSignedIn() && myProfile().role == 'leader'; }
    function canViewAll() { return isSignedIn() && (myProfile().role == 'leader' || myProfile().role == 'viewer'); }
    function myBranch() { return myProfile().branchId; }

    // 사용자 프로필: 본인은 생성 가능, 본인 또는 팀장은 읽기/수정 가능
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isLeader());
      allow delete: if isLeader();
    }

    // 지점 목록: 회원가입 화면에서 선택해야 하므로 누구나 읽기 가능, 쓰기는 팀장만
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isLeader();
    }

    // 팀 전체 공용 자료 - 팀장만 작성/수정 (팀장 일정, 공지사항, 리더십 자료)
    match /scheduleEntries/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    match /notices/{id}     { allow read: if isSignedIn(); allow write: if isLeader(); }
    match /leadership/{id}  { allow read: if isSignedIn(); allow write: if isLeader(); }

    // 사용자 정의 폴더 - 팀장만 폴더 생성/삭제, 로그인한 누구나 목록 조회
    match /customFolders/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 기존 메뉴의 이름/그룹/색상 수정본 - 팀장만 수정, 로그인한 누구나 조회
    match /menuOverrides/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 폴더 안의 게시물 - 팀장은 항상 가능, 폴더가 "전원 작성 가능"이면 로그인한 누구나 작성 가능
    match /folderEntries/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isLeader() ||
        get(/databases/$(database)/documents/customFolders/$(request.resource.data.folderId)).data.writable == 'all'
      );
      allow update, delete: if isSignedIn() && (
        isLeader() ||
        get(/databases/$(database)/documents/customFolders/$(resource.data.folderId)).data.writable == 'all'
      );
    }

    // 팀 전체 협업 자료 - 로그인한 누구나 작성/수정 (팀 회의 일지, 스터디 자료)
    match /teamMeetings/{id} { allow read, write: if isSignedIn(); }
    match /study/{id}        { allow read, write: if isSignedIn(); }

    // 지점 운영 자료 대시보드 - 양식(행) 종류는 팀장만 관리
    match /opsCategories/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 지점 운영 자료 링크 - 팀장은 전체, 팀원은 자기 지점 칸만 수정 (전체 열람은 모두 가능)
    match /opsLinks/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isLeader() || request.resource.data.branchId == myBranch());
      allow delete: if isSignedIn() && (isLeader() || resource.data.branchId == myBranch());
    }

    // 성과 지표 - 구글 시트 탭(연도) 등록 정보. 팀장만 추가/삭제, 로그인한 누구나 조회
    match /evalSheets/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 여러 화면에 붙는 단순 링크 버튼(예: 손익계산서) - 팀장만 수정
    match /siteLinks/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }

    // 지점 인적 구성 - 팀장만 수정, 로그인한 누구나 조회
    match /rosterEntries/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }

    // 지점별 데이터 - 팀장은 전체, 팀원은 자기 담당 지점 데이터만, viewer(예: 대표님)는 전체 열람만
    match /directorMeetings/{id} { allow read: if canViewAll(); allow write: if isLeader(); }
    match /memberMeetings/{id}   { allow read: if isSignedIn() && (canViewAll() || resource.data.branchId == myBranch());
                                    allow write: if isSignedIn() && (isLeader() || resource.data.branchId == myBranch());
                                    allow create: if isSignedIn() && (isLeader() || request.resource.data.branchId == myBranch()); }
    match /performance/{id}      { allow read: if isSignedIn() && (canViewAll() || resource.data.branchId == myBranch());
                                    allow write: if isSignedIn() && (isLeader() || resource.data.branchId == myBranch());
                                    allow create: if isSignedIn() && (isLeader() || request.resource.data.branchId == myBranch()); }
  }
}
