rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isLeader() { return isSignedIn() && myProfile().role == 'leader'; }
    function canViewAll() { return isSignedIn() && (myProfile().role == 'leader' || myProfile().role == 'viewer'); }
    function myBranch() { return myProfile().branchId; }

    // 팀장이 "전체 메뉴 관리"에서 기존 메뉴의 작성/열람 권한을 바꾼 값이 있으면 그 값을, 없으면 defaultVal을 사용
    function menuOverride(key) {
      return exists(/databases/$(database)/documents/menuOverrides/$(key))
        ? get(/databases/$(database)/documents/menuOverrides/$(key)).data
        : {};
    }
    function sectionWritable(key, defaultVal) { return menuOverride(key).get('writable', defaultVal); }
    function sectionLeaderOnly(key, defaultLeaderOnly) {
      return menuOverride(key).get('visibility', defaultLeaderOnly ? 'leader' : 'all') == 'leader';
    }

    // 사용자 프로필: 본인은 생성 가능, 본인 또는 팀장은 읽기/수정 가능
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isLeader());
      allow delete: if isLeader();
    }

    // 지점 목록: 회원가입 화면에서 선택해야 하므로 누구나 읽기 가능, 쓰기는 팀장만
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isLeader();
    }

    // 팀 전체 공용 자료 - 기본은 팀장만 작성/수정이지만, "전체 메뉴 관리"에서 작성 권한을 "전원"으로 바꾸면 로그인한 누구나 작성 가능
    match /scheduleEntries/{id} { allow read: if isSignedIn(); allow write: if isLeader() || sectionWritable('schedule', 'leader') == 'all'; }
    match /notices/{id}     { allow read: if isSignedIn(); allow write: if isLeader() || sectionWritable('notice', 'leader') == 'all'; }
    match /leadership/{id}  { allow read: if isSignedIn(); allow write: if isLeader() || sectionWritable('leadership', 'leader') == 'all'; }

    // 사용자 정의 폴더 - 팀장만 폴더 생성/삭제, 로그인한 누구나 목록 조회
    match /customFolders/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 기존 메뉴의 이름/그룹/색상 수정본 - 팀장만 수정, 로그인한 누구나 조회
    match /menuOverrides/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 폴더 안의 게시물 - 팀장은 항상 가능, 폴더가 "전원 작성 가능"이면 로그인한 누구나 작성 가능
    match /folderEntries/{id} {
      allow read: if isSignedIn() && (
        canViewAll() ||
        get(/databases/$(database)/documents/customFolders/$(resource.data.folderId)).data.get('visibility', 'all') != 'leader'
      );
      allow create: if isSignedIn() && (
        isLeader() ||
        get(/databases/$(database)/documents/customFolders/$(request.resource.data.folderId)).data.writable == 'all'
      );
      allow update, delete: if isSignedIn() && (
        isLeader() ||
        get(/databases/$(database)/documents/customFolders/$(resource.data.folderId)).data.writable == 'all'
      );
    }

    // 팀 전체 협업 자료 - 기본은 로그인한 누구나 작성/수정 (팀 회의 일지, 스터디 자료). "전체 메뉴 관리"에서 "팀장만"으로 바꾸면 팀장만 작성 가능
    match /teamMeetings/{id} { allow read: if isSignedIn(); allow write: if isSignedIn() && (isLeader() || sectionWritable('teamMeeting', 'all') != 'leader'); }
    match /study/{id}        { allow read: if isSignedIn(); allow write: if isSignedIn() && (isLeader() || sectionWritable('study', 'all') != 'leader'); }

    // 지점 운영 자료 대시보드 - 양식(행) 종류는 팀장만 관리
    match /opsCategories/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 지점 운영 자료 링크 - 팀장은 전체, 팀원은 자기 지점 칸만 수정 (전체 열람은 모두 가능)
    match /opsLinks/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isLeader() || request.resource.data.branchId == myBranch());
      allow delete: if isSignedIn() && (isLeader() || resource.data.branchId == myBranch());
    }

    // 성과 지표 - 구글 시트 탭(연도) 등록 정보. 팀장만 추가/삭제, 로그인한 누구나 조회
    match /evalSheets/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }
    // 여러 화면에 붙는 단순 링크 버튼(예: 손익계산서) - 팀장만 수정
    match /siteLinks/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }

    // 지점 인적 구성 - 팀장만 수정, 로그인한 누구나 조회
    match /rosterEntries/{id} { allow read: if isSignedIn(); allow write: if isLeader(); }

    // 지점별 데이터 - 기본은 팀장은 전체, 팀원은 자기 담당 지점 데이터만, viewer(예: 대표님)는 전체 열람만.
    // "전체 메뉴 관리"에서 열람/작성 권한을 바꾸면 아래 규칙에도 그대로 반영됩니다.
    match /directorMeetings/{id} {
      allow read: if isSignedIn() && (canViewAll() || !sectionLeaderOnly('directorMeeting', true));
      allow write: if isSignedIn() && (
        isLeader() ||
        sectionWritable('directorMeeting', 'leader') == 'all' ||
        (sectionWritable('directorMeeting', 'leader') == 'leader-and-branch' && resource.data.branchId == myBranch())
      );
      allow create: if isSignedIn() && (
        isLeader() ||
        sectionWritable('directorMeeting', 'leader') == 'all' ||
        (sectionWritable('directorMeeting', 'leader') == 'leader-and-branch' && request.resource.data.branchId == myBranch())
      );
    }
    match /memberMeetings/{id} {
      allow read: if isSignedIn() && (canViewAll() || (!sectionLeaderOnly('memberMeeting', false) && resource.data.branchId == myBranch()));
      allow write: if isSignedIn() && (
        isLeader() ||
        sectionWritable('memberMeeting', 'leader-and-branch') == 'all' ||
        (sectionWritable('memberMeeting', 'leader-and-branch') == 'leader-and-branch' && resource.data.branchId == myBranch())
      );
      allow create: if isSignedIn() && (
        isLeader() ||
        sectionWritable('memberMeeting', 'leader-and-branch') == 'all' ||
        (sectionWritable('memberMeeting', 'leader-and-branch') == 'leader-and-branch' && request.resource.data.branchId == myBranch())
      );
    }
    match /performance/{id}      { allow read: if isSignedIn() && (canViewAll() || resource.data.branchId == myBranch());
                                    allow write: if isSignedIn() && (isLeader() || resource.data.branchId == myBranch());
                                    allow create: if isSignedIn() && (isLeader() || request.resource.data.branchId == myBranch()); }
  }
}
